library(tidyverse)
library(purrr)
library(dplyr)
library(data.table)
library(readxl)
library(ggplot2)
library(ggpubr)
library(ggrepel)
library(ggthemes)
library(patchwork)
library(tibble)
library(corrplot)
stimuli <- suppressMessages(
read_excel("../stimuli/670CorpusMasterSheet_final.xlsx"))
# Grab relevant columns, sort by Category, mark and exclude items w/ no category label
stimuli_clean <- stimuli %>%
select(Name, Category) %>%
mutate(Category = ifelse(is.na(Category) | Category == "NA", "Unspecified", Category)) %>%
arrange(Category)
View(stimuli)
stimuli <- suppressMessages(
read_excel("../stimuli/670CorpusMasterSheet_final.xlsx"))%>%rename("Name"="NormName")
# Grab relevant columns, sort by Category, mark and exclude items w/ no category label
stimuli_clean <- stimuli %>%
select(Name, Category) %>%
mutate(Category = ifelse(is.na(Category) | Category == "NA", "Unspecified", Category)) %>%
arrange(Category)
stimuli <- suppressMessages(
read_excel("../stimuli/670CorpusMasterSheet_final.xlsx"))%>%rename("Name"="NormName")%>%select(Name)
stimuli <- suppressMessages(
read_excel("../stimuli/670CorpusMasterSheet_final.xlsx"))%>%rename("Name"="NormName")%>%select(Name)
write_csv(stimuli,"full_670_stimuli.csv")
